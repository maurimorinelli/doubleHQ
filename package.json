{
  "name": "doublehq-copilot",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:web": "npm run dev --workspace=packages/web",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/api && npm run build --workspace=packages/web",
    "seed": "npm run seed --workspace=packages/api",
    "migration:run": "npm run migration:run --workspace=packages/api",
    "migration:generate": "npm run migration:generate --workspace=packages/api",
    "setup": "docker-compose up -d && sleep 2 && npm run migration:run && npm run seed",
    "test": "npm test --workspace=packages/api",
    "test:unit": "npm run test:unit --workspace=packages/api",
    "test:integration": "npm run test:integration --workspace=packages/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}