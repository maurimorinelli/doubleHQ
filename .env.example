# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doublehq
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=doublehq

# ─── API Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=change-me-generate-a-strong-random-secret

# ─── AI (Claude) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Logging ────────────────────────────────────────────
# Controls which log levels are printed: DEBUG | INFO | WARN | ERROR
# DEBUG = show everything (default in development)
# WARN  = only warnings and errors (recommended for production)
LOG_LEVEL=DEBUG

# ─── Seed ───────────────────────────────────────────────
# Password assigned to all demo users when running npm run seed
SEED_DEFAULT_PASSWORD=change-me-pick-a-demo-password
